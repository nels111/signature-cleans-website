# Signature Cleans Website - Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000

# Admin Panel Password
ADMIN_PASSWORD=changeme

# Email Configuration (Ionos SMTP)
SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@signature-cleans.co.uk
SMTP_PASS=your_email_password

# Email Recipients
EMAIL_FROM=hello@signature-cleans.co.uk
EMAIL_TO=hello@signature-cleans.co.uk

# Zoho CRM Integration (Optional)
# Get credentials from https://api-console.zoho.eu/
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_DOMAIN=eu
